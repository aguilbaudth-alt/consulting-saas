# Auth0 SPA application (Application Type: Single Page Application).
# Domain and Client ID are safe to expose in frontend code — that's how Auth0's
# PKCE flow for SPAs works, no client secret needed.
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=replace-with-your-auth0-client-id

# Google Apps Script Web App URL (see /google-apps-script/Code.gs for setup).
VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/your-deployment-id/exec
